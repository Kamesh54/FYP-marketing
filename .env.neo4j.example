# Neo4j Configuration
# Required for knowledge graph functionality

# For Local Docker setup:
# NEO4J_ENABLED=True
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
# NEO4J_DATABASE=neo4j

# For Aura cloud setup:
# NEO4J_ENABLED=True
# NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
# NEO4J_USER=your_aura_instance_id
# NEO4J_PASSWORD=your_aura_password
# NEO4J_DATABASE=neo4j

# Uncomment and fill in your credentials below:
# NEO4J_ENABLED=True
# NEO4J_URI=
# NEO4J_USER=
# NEO4J_PASSWORD=
# NEO4J_DATABASE=

# Connection pooling and performance
NEO4J_POOL_SIZE=50
NEO4J_TIMEOUT=30
NEO4J_KEEPALIVE=60

# SSL/TLS (set to False for local development)
NEO4J_TRUST_CERTS=TRUST_ALL_CERTIFICATES

# Optional: For remote Neo4j instances
# NEO4J_URI=neo4j+s://your-neo4j-server.com:7687
# NEO4J_TRUST_CERTS=TRUST_SYSTEM_CA_SIGNED_CERTIFICATES

# Add these to your existing .env file for your framework
