# ═══════════════════════════════════════════════════════════════════════════
# FYP Marketing Platform - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────
# PROTOCOL SETTINGS (MCP & A2A)
# ──────────────────────────────────────────────────────────────────────────

# Enable Model Context Protocol (MCP) - Exposes agents as LLM tools
ENABLE_MCP=true

# Enable Agent-to-Agent Protocol (A2A) - Inter-agent communication
ENABLE_A2A=true

# A2A Host URL (for AgentCard discovery)
A2A_HOST=http://localhost:8004

# ──────────────────────────────────────────────────────────────────────────
# LLM API KEYS
# ──────────────────────────────────────────────────────────────────────────

# Groq API (required for most agents)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (optional, for advanced features)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (optional, for Claude integration)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ──────────────────────────────────────────────────────────────────────────
# SEARCH & DATA APIs
# ──────────────────────────────────────────────────────────────────────────

# SerpAPI for Google Search results
SERPAPI_KEY=your_serpapi_key_here

# ──────────────────────────────────────────────────────────────────────────
# SOCIAL MEDIA CREDENTIALS
# ──────────────────────────────────────────────────────────────────────────

# Twitter/X API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# Instagram (Instagrapi)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FYP-Marketing-Platform/1.0

# ──────────────────────────────────────────────────────────────────────────
# IMAGE GENERATION
# ──────────────────────────────────────────────────────────────────────────

# Runway ML API (for video/advanced image generation)
RUNWAY_API_KEY=your_runway_api_key

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=your_stability_api_key

# ──────────────────────────────────────────────────────────────────────────
# AWS CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=us-east-1

# ──────────────────────────────────────────────────────────────────────────
# LANGGRAPH & OBSERVABILITY
# ──────────────────────────────────────────────────────────────────────────

# Enable LangGraph orchestration (recommended)
USE_LANGGRAPH=true

# LangSmith tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=fyp-marketing

# ──────────────────────────────────────────────────────────────────────────
# KNOWLEDGE GRAPH (Neo4j)
# ──────────────────────────────────────────────────────────────────────────

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ──────────────────────────────────────────────────────────────────────────
# VECTOR STORE (ChromaDB)
# ──────────────────────────────────────────────────────────────────────────

CHROMA_PERSIST_DIRECTORY=./chroma_db

# ──────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ──────────────────────────────────────────────────────────────────────────

# JWT Secret (generate a random string)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production

# Token expiration (in minutes)
JWT_EXPIRATION_MINUTES=1440

# ──────────────────────────────────────────────────────────────────────────
# MICROSERVICE URLS (usually defaults work)
# ──────────────────────────────────────────────────────────────────────────

CRAWLER_BASE=http://127.0.0.1:8000
KEYWORD_EXTRACTOR_BASE=http://127.0.0.1:8001
GAP_ANALYZER_BASE=http://127.0.0.1:8002
CONTENT_AGENT_BASE=http://127.0.0.1:8003
ORCHESTRATOR_BASE=http://127.0.0.1:8004
SEO_AGENT_BASE=http://127.0.0.1:5000
IMAGE_AGENT_BASE=http://127.0.0.1:8005
BRAND_AGENT_BASE=http://127.0.0.1:8006
CRITIC_AGENT_BASE=http://127.0.0.1:8007
CAMPAIGN_AGENT_BASE=http://127.0.0.1:8008
RESEARCH_AGENT_BASE=http://127.0.0.1:8009
REDDIT_AGENT_BASE=http://127.0.0.1:8010

# ──────────────────────────────────────────────────────────────────────────
# MABO REINFORCEMENT LEARNING
# ──────────────────────────────────────────────────────────────────────────

# Enable MABO optimization
ENABLE_MABO=true

# MABO learning rate
MABO_LEARNING_RATE=0.01

# MABO exploration rate
MABO_EXPLORATION_RATE=0.1

# ──────────────────────────────────────────────────────────────────────────
# DEVELOPMENT & DEBUGGING
# ──────────────────────────────────────────────────────────────────────────

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

